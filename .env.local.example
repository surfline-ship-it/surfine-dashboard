# HubSpot Private App Token (create at Settings > Integrations > Private Apps)
# Scopes needed: crm.objects.contacts.read, crm.objects.deals.read, crm.objects.companies.read
HUBSPOT_ACCESS_TOKEN=pat-na2-xxxxxxxx

# JWT secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-random-secret-here

# Partner credentials (JSON map of password -> partner config)
# Format: { "password": { "partner": "Trivest", "label": "Trivest Partners" } }
PARTNER_CREDENTIALS={"trivest2026":{"partner":"Trivest","label":"Trivest Partners"},"incline2026":{"partner":"Incline","label":"Incline Equity Partners"}}
